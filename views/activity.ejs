<%- include('partials/head.ejs', {
    title : ""
}); -%>

<body class="guest-top guest" data-token="">    
    <div id="wrapper">
    <% if (session.innoverseid) { %>
        <% const url_id = "/users/" + encodeURIComponent(session.innoverseid); %>
        <div id="sub-body">
            <menu id="global-menu">
                <li id="global-menu-logo">
                    <h1><img src="../img/innoverse_logo.png" alt="Innoverse" width="1159" height="238"></h1>
                </li>
                <li id="global-menu-mymenu">
                    <a href="<%= url_id %>">
                        <span class="icon-container">
                            <img src="../img/default_mii/normal_face.png" alt="user page">
                        </span>
                        <span><%= session.innoverseid %></span>
                    </a>
                </li>
                <li id="global-menu-feed" class="selected">
                    <a href="/activity" class="symbol">
                        <span>Activity Feed</span>
                    </a>
                </li>
                <li id="global-menu-community">
                    <a href="/communities" class="symbol">
                        <span>Communities</span>
                    </a>
                </li>
                <li id="global-menu-news">
                    <a href="/notifications" class="symbol">
                        <span>Notifications</span>
                        <span class="badge" style="display: none;">0</span>
                    </a>
                </li>
            </menu>
        </div>
    <% } else { %>
        <div id="sub-body">
            <menu>
                <li id="global-menu-logo"><h1><img src="/static/img/innoverse_logo.png" alt="Innoverse" width="200" height="55"></h1></li>
                <li id="global-menu-login">
                    <form id="login_form" action="/login" method="get">
                        <input type="submit" class="black-button" value="Sign in">
                    </form>
                </li>
            </menu>
        </div>
    <% } %>

        <div id="main-body">
            <div class="body-content" id="community-top">
                <div class="headline">
                    <h2 class="headline-text">Activity Feed</h2>
                    <form method="GET" action="/titles/search" class="search">
                        <input type="text" name="query" placeholder="Search" minlength="2" maxlength="20"><input type="submit" value="q" title="Search">
                    </form>
                </div>
            </div>
        </div>
        <div id="footer">
            <div id="sidebar"></div>
            <p id="copyright">InnoverseTeam</p>
        </div>
    </div>
</body>
</html>
