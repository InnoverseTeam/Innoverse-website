<%- include('partials/head.ejs', {
title : ""
}); -%>

<body class="guest-top guest" data-token="">
<div id="wrapper">
<% if (session.innoverseid) { %>
    <% const url_id = "/users/" + encodeURIComponent(session.innoverseid); %>
<div id="sub-body">
    <menu id="global-menu">
        <li id="global-menu-logo">
            <h1><img src="../img/innoverse_logo.png" alt="Innoverse" width="1159" height="238"></h1>
        </li>
        <li id="global-menu-mymenu">
            <a href="<%= url_id %>">
                <span class="icon-container">
                    <img src="../img/default_mii/normal_face.png" alt="user page">
                </span>
                <span><%= session.innoverseid %></span>
            </a>
        </li>
        <li id="global-menu-feed">
            <a href="/activity" class="symbol">
                <span>Activity Feed</span>
            </a>
        </li>
        <li id="global-menu-community" class="selected">
            <a href="/communities" class="symbol">
                <span>Communities</span>
            </a>
        </li>
        <li id="global-menu-news">
            <a href="/notifications" class="symbol">
                <span>Notifications</span>
                <span class="badge" style="display: none;">0</span>
            </a>
        </li>
    </menu>
</div>
<% } else { %>
<div id="sub-body">
    <menu id="">
        <li id="global-menu-logo">
            <h1><img src="../img/innoverse_logo.png" alt="Innoverse" width="1159" height="238"></h1>
        </li>
        <li id="global-menu-login">
            <form id="login_form" action="/login" method="get">
                <input type="submit" class="black-button" value="Sign in">
            </form>
        </li>
    </menu>
</div>
<% } %>
<div id="main-body">
    <h2 class="welcome-message">Welcome to Innoverse!</h2>
    <div id="about">
        <img src="https://www.archiverse.app/_next/image?url=%2Fwelcome-image.png&w=640&q=75" alt="Welcome Image">
        <p>
            Innoverse is a service that lets you communicate with other players from around the world. It is accessible via Wii U and systems in the Nintendo 3DS family.
        </p>
    </div>
    <div class="body-content" id="community-top">
        <div class="headline">
            <h2 class="headline-text">Communities</h2>
            <form method="GET" action="/titles/search" class="search">
                <input type="text" name="query" placeholder="Search" minlength="2" maxlength="20"><input type="submit" value="q" title="Search">
            </form>
        </div>
        <div id="identified-user-banner">
            <a href="/identified_user_posts" data-pjax="#body" class="list-button us">
                <span class="title">Get the latest news here!</span>
                <span class="text">Posts from Verified Users</span>
            </a>
        </div>
        <div id="tab-wiiu-body" class="tab-body">
            <ul class="list community-list community-title-list">
                <li id="community-0" class="trigger " data-href="" tabindex="0">
                    <span class="icon-container"><img src="https://web.archive.org/web/20171014154111im_/https://d3esbfg30x759i.cloudfront.net/tip/AAUAABAUVgABEXzibm" class="icon"></span>
                    <div class="body">
                        <a class="title" href="/titles/0005000010145600/0" tabindex="-1">Animal Crossing Series Community</a>
                        <span class="platform-tag"><img src="../img/platform-tag-wiiu.png" alt="Wii U"></span>
                        <span class="text">grp.wiiu_games</span>
                    </div>
                </li>
                <li id="community" class="trigger " data-href="" tabindex="0">
                    <span class="icon-container"><img src="https://web.archive.org/web/20171014154111im_/https://d3esbfg30x759i.cloudfront.net/tip/AAUAABAQ6wAZhTvmBF" class="icon"></span>
                    <div class="body">
                        <a class="title" href="" tabindex="-1">Mario Kart 8 Community</a>
                        <span class="platform-tag"><img src="../img/platform-tag-wiiu.png" alt="Wii U"></span>
                        <span class="text">grp.wiiu_games</span> 
                    </div>
                </li>
                <li id="community" class="trigger " data-href="" tabindex="0">
                    <span class="icon-container"><img src="https://web.archive.org/web/20171014154111im_/https://d3esbfg30x759i.cloudfront.net/tip/AAUAABAXaQAWV-1E_o" class="icon"></span>
                    <div class="body">
                        <a class="title" href="" tabindex="-1">Splatoon Community</a>
                        <span class="platform-tag"><img src="../img/platform-tag-wiiu.png" alt="Wii U"></span>
                        <span class="text">grp.wiiu_games</span>
                    </div>
                </li>
                <li id="community" class="trigger " data-href="" tabindex="0">
                    <span class="icon-container"><img src="https://web.archive.org/web/20171014154111im_/https://d3esbfg30x759i.cloudfront.net/tip/AAUAABAdvgApDXIpUJ" class="icon"></span>
                    <div class="body">
                        <a class="title" href="" tabindex="-1">Minecraft Community</a>
                        <span class="platform-tag"><img src="../img/platform-tag-wiiu.png" alt="Wii U"></span>
                        <span class="text">grp.wiiu_games</span>
                    </div>
                </li>
                <li id="community" class="trigger " data-href="" tabindex="0">
                    <span class="icon-container"><img src="https://web.archive.org/web/20171014154111im_/https://d3esbfg30x759i.cloudfront.net/tip/AAUAABAQIAA_-dxQTf" class="icon"></span>
                    <div class="body">
                        <a class="title" href="" tabindex="-1">Nintendo Land Community</a>
                        <span class="platform-tag"><img src="../img/platform-tag-wiiu.png" alt="Wii U"></span>
                        <span class="text">grp.wiiu_games</span>
                    </div>
                </li>
            </ul>
            <div class="buttons-content">
                <a href="/communities/categories/wiiu_all" class="button">Show more</a>
            </div>
        </div>
    </div>
    <div id="footer">
        <div id="sidebar"></div>
        <br><br><br><br><br><br>
        <p id="copyright">InnoverseTeam</p>
    </div>
</div>
</body>
</html>